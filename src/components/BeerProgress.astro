---
type Props = {
  username: string;
  displayName: string;
  avatarUrl?: string;
  current: number;
  target: number;
  source?: string;
  updatedAt?: string;
};

const {
  username,
  displayName,
  avatarUrl = '/badge.svg',
  current,
  target,
  source = 'fallback',
  updatedAt = '',
} = Astro.props;
---

<beer-progress-card
  username={username}
  display-name={displayName}
  avatar-url={avatarUrl || '/badge.svg'}
  current={current}
  target={target}
  source={source}
  updated-at={updatedAt}
></beer-progress-card>

<script>
  class BeerProgressCard extends HTMLElement {
    connectedCallback(): void {
      const username = this.getAttribute('username') || 'Snoothy';
      const displayName = this.getAttribute('display-name') || username;
      const avatarUrl = this.getAttribute('avatar-url') || '/badge.svg';
      const current = Number(this.getAttribute('current') || 0);
      const target = Math.max(Number(this.getAttribute('target') || 1000), 1);
      const source = this.getAttribute('source') || 'fallback';
      const updatedAt = this.getAttribute('updated-at') || '';
      const percentage = Math.min(100, Math.round((current / target) * 100));
      const remaining = Math.max(target - current, 0);
      const isLive = source === 'scraped' || source === 'untappd';
      const formatter = new Intl.NumberFormat('en-US');
      const updatedText = this.formatUpdatedAt(updatedAt);
      const root = this.shadowRoot ?? this.attachShadow({ mode: 'open' });

      root.innerHTML = `
        <style>
          :host {
            display: block;
            width: 100%;
            min-height: 100svh;
            color: #fff8e8;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          }

          * { box-sizing: border-box; }

          .frame {
            position: relative;
            width: 100%;
            min-height: 100svh;
            display: grid;
            place-items: center;
            overflow: hidden;
            padding: clamp(1.25rem, 4vw, 4rem);
            background:
              radial-gradient(circle at 20% 6%, rgba(255, 179, 37, 0.26), transparent 15rem),
              radial-gradient(circle at 86% 43%, rgba(146, 77, 7, 0.34), transparent 24rem),
              radial-gradient(circle at 70% 115%, rgba(255, 145, 0, 0.16), transparent 23rem),
              linear-gradient(105deg, #050402 0%, #070604 44%, #010101 100%);
            isolation: isolate;
          }

          .frame::before,
          .frame::after {
            position: absolute;
            content: '';
            pointer-events: none;
            z-index: -1;
          }

          .frame::before {
            width: 34rem;
            height: 34rem;
            right: -11rem;
            top: 18rem;
            border-radius: 50%;
            background:
              radial-gradient(circle at 38% 32%, rgba(255, 208, 96, 0.5), transparent 0.15rem),
              radial-gradient(circle at 58% 42%, rgba(255, 184, 45, 0.42), transparent 0.18rem),
              radial-gradient(circle at 44% 68%, rgba(255, 194, 63, 0.28), transparent 0.16rem),
              radial-gradient(circle at 57% 56%, rgba(147, 80, 10, 0.68), transparent 17rem);
            background-size: 6rem 6rem, 5.2rem 5.2rem, 7rem 7rem, 100% 100%;
            opacity: 0.78;
          }

          .frame::after {
            inset: 0;
            background-image: radial-gradient(circle, rgba(255, 199, 78, 0.25) 0 1px, transparent 1.25px);
            background-size: 5.25rem 5.25rem;
            mask-image: linear-gradient(90deg, transparent, black 48%, transparent 92%);
            opacity: 0.16;
          }

          .content {
            width: min(100%, 58rem);
            display: flex;
            flex-direction: column;
            gap: clamp(2rem, 5vw, 4.6rem);
          }

          .profile {
            display: grid;
            grid-template-columns: auto 1fr;
            align-items: center;
            gap: clamp(1.5rem, 4vw, 3rem);
          }

          .avatar {
            width: clamp(8.5rem, 18vw, 14.8rem);
            aspect-ratio: 1;
            display: grid;
            place-items: center;
            overflow: hidden;
            border: clamp(0.24rem, 0.8vw, 0.42rem) solid #ffbd3f;
            border-radius: 50%;
            background: #090807;
            box-shadow:
              0 0 0 1rem rgba(255, 169, 20, 0.1),
              0 0 3rem rgba(255, 168, 17, 0.6),
              inset 0 0 3rem rgba(0, 0, 0, 0.62);
          }

          .avatar img { width: 100%; height: 100%; object-fit: cover; }

          .name {
            margin: 0;
            color: #fff8ed;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: clamp(3.5rem, 9vw, 7.1rem);
            line-height: 0.85;
            letter-spacing: -0.065em;
            text-shadow: 0 0 1.6rem rgba(255, 224, 163, 0.18);
          }

          .tagline {
            margin: 0.55rem 0 1.25rem;
            color: #c0ad9a;
            font-size: clamp(1.1rem, 2.6vw, 2.05rem);
            font-weight: 800;
          }

          .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0.8rem 1.8rem;
            border: 1px solid rgba(170, 94, 38, 0.68);
            border-radius: 999px;
            background: rgba(0, 0, 0, 0.3);
            color: #fff8ed;
            font-size: clamp(1rem, 2.4vw, 1.9rem);
            font-weight: 900;
            box-shadow: inset 0 0 1.5rem rgba(255, 157, 0, 0.07);
          }

          .card {
            position: relative;
            z-index: 0;
            overflow: hidden;
            padding: clamp(3rem, 7vw, 6.5rem) clamp(1.7rem, 5vw, 4.1rem) clamp(2.2rem, 5vw, 5.1rem);
            border: 1px solid rgba(179, 98, 42, 0.62);
            border-radius: clamp(1.6rem, 4vw, 3.4rem);
            background:
              linear-gradient(90deg, rgba(255, 169, 24, 0) 0 66%, rgba(151, 91, 14, 0.44) 66% 100%),
              radial-gradient(circle at 86% 22%, rgba(255, 188, 55, 0.13), transparent 18rem),
              linear-gradient(145deg, rgba(10, 9, 6, 0.96), rgba(5, 4, 3, 0.98));
            box-shadow: 0 1rem 4rem rgba(0, 0, 0, 0.64), inset 0 0 4.5rem rgba(255, 170, 31, 0.035);
          }

          .card::after {
            position: absolute;
            inset: 0 0 auto auto;
            width: 43%;
            height: 100%;
            content: '';
            background:
              radial-gradient(circle at 25% 8%, rgba(255, 205, 89, 0.32), transparent 0.14rem),
              radial-gradient(circle at 63% 25%, rgba(255, 190, 48, 0.25), transparent 0.18rem),
              radial-gradient(circle at 43% 50%, rgba(255, 201, 74, 0.2), transparent 0.13rem),
              radial-gradient(circle at 74% 72%, rgba(255, 174, 31, 0.18), transparent 0.16rem);
            background-size: 5rem 5rem, 6rem 6rem, 4.8rem 4.8rem, 5.4rem 5.4rem;
            opacity: 0.6;
            pointer-events: none;
          }

          .ornament {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.8rem;
            margin-bottom: clamp(1.8rem, 4vw, 4rem);
            color: #f6a51c;
            font-size: 1.5rem;
          }

          .ornament::before,
          .ornament::after {
            width: 4rem;
            height: 1px;
            content: '';
            background: linear-gradient(90deg, transparent, rgba(246, 165, 28, 0.85));
          }

          .ornament::after { background: linear-gradient(90deg, rgba(246, 165, 28, 0.85), transparent); }

          h1 {
            max-width: 12ch;
            margin: 0 auto clamp(2.2rem, 5vw, 4.7rem);
            color: #fff8ed;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: clamp(3.5rem, 10.5vw, 7.7rem);
            line-height: 0.88;
            letter-spacing: -0.06em;
            text-align: left;
            text-shadow: 0 0 1.8rem rgba(255, 218, 151, 0.13);
          }

          .count {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: clamp(0.55rem, 2.2vw, 1.8rem);
            margin-bottom: clamp(2rem, 4vw, 4rem);
            line-height: 0.9;
          }

          .current {
            color: #ffb11e;
            font: 900 clamp(5.4rem, 17vw, 11.2rem) Inter, ui-sans-serif, system-ui, sans-serif;
            letter-spacing: -0.09em;
            text-shadow: 0 0 0.2rem #ffe79b, 0 0 1.1rem rgba(255, 172, 15, 0.85), 0 0 3.2rem rgba(255, 124, 0, 0.55);
          }

          .target {
            color: #d0c2b3;
            font: 500 clamp(4.1rem, 13vw, 9rem) Georgia, 'Times New Roman', serif;
            letter-spacing: -0.09em;
            text-shadow: 0 0 1.2rem rgba(255, 226, 188, 0.25);
          }

          .bar {
            position: relative;
            height: clamp(3.25rem, 7vw, 6.2rem);
            overflow: hidden;
            border: 0.32rem solid rgba(120, 62, 30, 0.95);
            border-radius: 999px;
            background: rgba(4, 4, 3, 0.95);
            box-shadow: inset 0 0 1.2rem rgba(0, 0, 0, 0.95), 0 0 2.2rem rgba(255, 156, 8, 0.2);
          }

          .fill {
            position: relative;
            width: ${percentage}%;
            min-width: 1rem;
            height: 100%;
            border-radius: inherit;
            background:
              radial-gradient(circle at 12% 58%, rgba(255, 239, 161, 0.9), transparent 0.14rem),
              radial-gradient(circle at 46% 55%, rgba(255, 238, 164, 0.62), transparent 0.18rem),
              radial-gradient(circle at 68% 54%, rgba(255, 238, 164, 0.5), transparent 0.14rem),
              linear-gradient(180deg, #ffe878 0%, #ffb529 44%, #e57909 100%);
            background-size: 6rem 6rem, 5rem 5rem, 4.6rem 4.6rem, 100% 100%;
            box-shadow: inset 0 0 1.3rem rgba(255, 255, 202, 0.42), 0 0 1.5rem rgba(255, 162, 0, 0.86), 0 0 3.5rem rgba(255, 123, 0, 0.56);
          }

          .fill::before {
            position: absolute;
            inset: 0.7rem 1.4rem auto;
            height: 0.42rem;
            content: '';
            border-radius: 999px;
            background: rgba(255, 255, 219, 0.84);
            filter: blur(0.08rem);
          }

          .fill::after {
            position: absolute;
            top: -0.65rem;
            right: -0.85rem;
            width: 1.8rem;
            height: 1.8rem;
            content: '';
            background: #fff4b8;
            clip-path: polygon(50% 0%, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0% 50%, 39% 39%);
            filter: drop-shadow(0 0 0.95rem #ffb21b);
          }

          .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            margin-top: clamp(2.4rem, 5vw, 5.5rem);
            padding-top: clamp(1.8rem, 4vw, 3.7rem);
            border-top: 1px solid rgba(255, 244, 219, 0.16);
          }

          .stat {
            display: grid;
            justify-items: center;
            gap: 0.75rem;
            padding: 0 clamp(0.7rem, 2vw, 2.3rem);
            text-align: center;
          }

          .stat + .stat { border-left: 1px solid rgba(255, 191, 97, 0.2); }

          .icon {
            position: relative;
            width: clamp(3.6rem, 7vw, 5.8rem);
            aspect-ratio: 1;
            display: grid;
            place-items: center;
            border: 1px solid rgba(168, 90, 37, 0.72);
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.24);
            color: #ffa51f;
          }

          .icon svg { width: 52%; height: 52%; stroke: currentColor; stroke-width: 2.4; fill: none; stroke-linecap: round; stroke-linejoin: round; }

          .dot {
            position: absolute;
            right: 0.35rem;
            bottom: 0.35rem;
            width: 0.75rem;
            height: 0.75rem;
            border-radius: 50%;
            background: #21d34d;
            box-shadow: 0 0 0.9rem #21d34d;
          }

          .value { color: #ffc64a; font: 800 clamp(1.7rem, 4vw, 3.25rem) Georgia, 'Times New Roman', serif; line-height: 1; }
          .label { color: #b8aa98; font-size: clamp(0.9rem, 2vw, 1.45rem); line-height: 1.2; }
          .link { color: inherit; text-decoration: none; }

          @media (max-width: 720px) {
            :host { min-height: 100svh; }
            .frame {
              min-height: 100svh;
              padding: 0.65rem;
              align-items: stretch;
            }
            .content {
              width: min(100%, 28rem);
              min-height: calc(100svh - 1.3rem);
              gap: 0.7rem;
              justify-content: center;
            }
            .profile {
              gap: 0.85rem;
              grid-template-columns: auto minmax(0, 1fr);
            }
            .avatar {
              width: clamp(4.2rem, 19vw, 5.7rem);
              border-width: 0.18rem;
              box-shadow: 0 0 0 0.35rem rgba(255, 169, 20, 0.1), 0 0 1.6rem rgba(255, 168, 17, 0.55);
            }
            .name { font-size: clamp(2rem, 11vw, 3rem); line-height: 0.86; }
            .tagline { margin: 0.25rem 0 0.45rem; font-size: clamp(0.78rem, 3.6vw, 1rem); }
            .badge { gap: 0.45rem; padding: 0.45rem 0.9rem; font-size: 0.82rem; }
            .card {
              padding: 1.1rem 0.95rem 0.95rem;
              border-radius: 1.35rem;
            }
            .ornament { gap: 1rem; margin-bottom: 0.8rem; font-size: 1rem; }
            .ornament::before, .ornament::after { width: 2.3rem; }
            h1 {
              max-width: 13ch;
              margin-bottom: 1rem;
              font-size: clamp(2.2rem, 13.5vw, 3.55rem);
              line-height: 0.86;
            }
            .count { gap: 0.45rem; margin-bottom: 1rem; }
            .current { font-size: clamp(3.6rem, 20vw, 5.25rem); }
            .target { font-size: clamp(2.9rem, 15vw, 4.15rem); }
            .bar { height: clamp(2.25rem, 10vw, 3rem); border-width: 0.24rem; }
            .fill::before { inset: 0.42rem 0.8rem auto; height: 0.28rem; }
            .fill::after { width: 1.1rem; height: 1.1rem; top: -0.38rem; right: -0.5rem; }
            .stats {
              grid-template-columns: repeat(3, minmax(0, 1fr));
              gap: 0;
              margin-top: 1rem;
              padding-top: 0.9rem;
            }
            .stat { gap: 0.35rem; padding: 0 0.35rem; }
            .stat + .stat { border-left: 1px solid rgba(255, 191, 97, 0.18); }
            .icon { width: clamp(2.2rem, 10vw, 2.8rem); }
            .value { font-size: clamp(1.2rem, 5.8vw, 1.65rem); }
            .label { font-size: clamp(0.62rem, 3vw, 0.82rem); }
          }

          @media (max-width: 380px), (max-height: 700px) {
            .content { gap: 0.5rem; }
            .avatar { width: 4rem; }
            .name { font-size: 2.2rem; }
            .tagline { display: none; }
            .badge { padding: 0.35rem 0.75rem; font-size: 0.72rem; }
            .card { padding: 0.85rem 0.75rem 0.75rem; }
            .ornament { margin-bottom: 0.45rem; }
            h1 { font-size: 2.35rem; margin-bottom: 0.75rem; }
            .current { font-size: 3.75rem; }
            .target { font-size: 2.9rem; }
            .bar { height: 2.15rem; }
            .stats { margin-top: 0.75rem; padding-top: 0.7rem; }
            .icon { width: 2rem; }
          }
        </style>

        <section class="frame" aria-labelledby="progress-title">
          <div class="content">
            <header class="profile">
              <a class="avatar link" href="https://untappd.com/user/${username}" aria-label="Open ${displayName} on Untappd">
                <img src="${avatarUrl}" alt="" />
              </a>
              <div>
                <h2 class="name">${displayName}</h2>
                <p class="tagline">Beer explorer. Flavor chaser.</p>
                <a class="badge link" href="https://untappd.com/user/${username}">
                  <span aria-hidden="true">🌾</span>
                  <span>Hoppy Explorer</span>
                </a>
              </div>
            </header>

            <article class="card">
              <div class="ornament" aria-hidden="true">🌾</div>
              <h1 id="progress-title">Road to ${formatter.format(target)} Unique Beers</h1>

              <div class="count" aria-label="${formatter.format(current)} of ${formatter.format(target)} unique beers">
                <span class="current">${formatter.format(current)}</span>
                <span class="target">/ ${formatter.format(target)}</span>
              </div>

              <div class="bar" role="progressbar" aria-valuemin="0" aria-valuemax="${target}" aria-valuenow="${current}" aria-label="Unique beer progress">
                <div class="fill"></div>
              </div>

              <div class="stats" aria-label="Progress summary">
                <div class="stat">
                  <div class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3v9h8"/><path d="M21 12a9 9 0 1 1-9-9"/></svg></div>
                  <div class="value">${percentage}%</div>
                  <div class="label">complete</div>
                </div>
                <div class="stat">
                  <div class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/><path d="m17 7 3-3"/><path d="M14 4h6v6"/></svg></div>
                  <div class="value">${formatter.format(remaining)}</div>
                  <div class="label">to go</div>
                </div>
                <div class="stat">
                  <div class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 12h4l3-7 4 14 3-7h4"/></svg>${isLive ? '<span class="dot"></span>' : ''}</div>
                  <div class="value">${isLive ? 'Live' : 'Demo'}</div>
                  <div class="label">${updatedText}</div>
                </div>
              </div>
            </article>
          </div>
        </section>
      `;
    }

    private formatUpdatedAt(value: string): string {
      if (!value) return 'Updated automatically';

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return 'Updated automatically';

      const diffMs = Date.now() - date.getTime();
      if (diffMs >= 0 && diffMs < 60 * 60 * 1000) return 'Updated just now';

      return `Updated ${date.toLocaleDateString('en-GB')}`;
    }
  }

  if (!customElements.get('beer-progress-card')) {
    customElements.define('beer-progress-card', BeerProgressCard);
  }
</script>
